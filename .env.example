GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
ADMIN_EMAIL=support@eazinvoice.com
ADMIN_EMAILS=info@eazinvoice.com,support@eazinvoice.com
ADMIN_ACCESS_KEY=eazinvoice-admin
EAZINVOICE_DATA_DIR=

# Postgres is optional until the production cutover is complete.
# Keep JSON as the default runtime storage unless this is explicitly changed.
DATABASE_URL=postgres://postgres:your_password@localhost:5432/eazinvoice
EAZINVOICE_POSTGRES_DUAL_WRITE=false
EAZINVOICE_CORE_TABLE_SYNC=false
EAZINVOICE_REPORTS_SOURCE=json
EAZINVOICE_ENTITLEMENTS_SOURCE=json
EAZINVOICE_STORAGE=json

OTP_CHANNEL=email
SMS_OTP_ENABLED=false
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_public_key
EMAIL_OTP_EXPIRES_SECONDS=90

# Optional fallback when Supabase cannot send auth OTP email.
# Use your company mailbox SMTP credentials, e.g. Namecheap Private Email.
EMAIL_SMTP_HOST=mail.privateemail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=info@eazinvoice.com
EMAIL_SMTP_PASS=your_mailbox_or_app_password
EMAIL_SMTP_FROM=info@eazinvoice.com
EMAIL_SMTP_FROM_NAME=EazInvoice
EMAIL_SMTP_SECURE=true

# Razorpay live checkout. Keep secrets only in Render/local .env, never in frontend code.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
EAZINVOICE_PUBLIC_URL=https://www.eazinvoice.com

# SMS OTP is disabled for now. Add a paid SMS/WhatsApp provider later before enabling mobile verification.
